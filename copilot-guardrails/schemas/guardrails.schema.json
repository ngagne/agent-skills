{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://your-company.com/schemas/guardrails.schema.json",
  "title": "Copilot Guardrails Policy",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "effect"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny", "approval"]
        },
        "tool": {
          "type": "string"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commandPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "outsideWorkspace": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
